# Copy this file to .env and fill in the values for your InfluxDB schema.
# .env is ignored by git so credentials stay local.

INFLUX_URL=http://10.0.11.125:8086
INFLUX_USERNAME=admin
INFLUX_PASSWORD=change-me

INFLUX_ORG=arduino
INFLUX_BUCKET=arduinostorage
INFLUX_MEASUREMENT=arduino

# Optional comma-separated tag filter, for example:
# INFLUX_TAG_FILTER=device_id=nano33,sensor=imu
INFLUX_TAG_FILTER=
INFLUX_RANGE=-15s
INFLUX_POLL_INTERVAL=0.2

# Default field names detected in this InfluxDB bucket. Change A to B if you
# want the second sensor stream.
INFLUX_FIELD_AX=A.ax_ms2
INFLUX_FIELD_AY=A.ay_ms2
INFLUX_FIELD_AZ=A.az_ms2
INFLUX_FIELD_GX=A.gx_dps
INFLUX_FIELD_GY=A.gy_dps
INFLUX_FIELD_GZ=A.gz_dps
INFLUX_FIELD_MX=mx
INFLUX_FIELD_MY=my
INFLUX_FIELD_MZ=mz
INFLUX_FIELD_R=r
INFLUX_FIELD_G=g
INFLUX_FIELD_B=b
INFLUX_FIELD_AMBIENT=amb
INFLUX_FIELD_PRESSURE=A.pressure_pa
INFLUX_ACCEL_UNIT=mps2
INFLUX_GYRO_UNIT=dps
INFLUX_PRESSURE_UNIT=pa

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=sensors/nano33/imu
MQTT_QOS=0

SENSOR_NAME=Sensor_IMU
SENSOR_MODE=double-integrate
SENSOR_ALPHA=0.98
POSITION_SCALE=1.0
RECORD_KEYFRAMES=false
BLENDER_HOST=127.0.0.1
BLENDER_PORT=9876
